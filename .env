 # Google Maps Directions API
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Bok Radio stream URL (extract from website)
BOK_RADIO_STREAM_URL=https://stream.bokradio.co.za/live/index.m3u8

# Google TTS (optional – remove if using another TTS)
GOOGLE_TTS_API_KEY=path/to/stormy-credentials.json

# Weather (OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweather_api_key

# Web Search (Google Custom Search)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# News (GNews API)
GNEWS_API_KEY=your_gnews_api_key
